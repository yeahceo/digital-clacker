{
  "$schema": "https://design-tokens.github.io/community-group/format/",
  "_meta": {
    "name": "디지털 클락커 · 왁뿌볼 디자인 토큰",
    "version": "1.0.0",
    "description": "Primitive → Semantic → Theme 구조. tokens.css가 런타임 구현체.",
    "themes": ["cute", "dark"]
  },

  "color": {
    "pink":   { "50":"#fdf0f4","100":"#ffd9e6","200":"#ffb3c8","300":"#f7c5d5","400":"#e6a6bd","700":"#b8086e" },
    "purple": { "100":"#cabfd4","300":"#b79fd0","400":"#c9a7e6","500":"#a981d6","700":"#5b3b6e" },
    "ink":    { "900":"#1b1b1f","700":"#443a4a" },
    "night":  { "900":"#110e16","700":"#1a1620","500":"#2a2230" },
    "wax":    { "cream-50":"#fbfbf7","cream-100":"#f3efe6","cream-200":"#eceae4","cream-300":"#e6e3da","cream-400":"#d7d4cd","shadow":"#b4afa4","crack":"#6e6a62" },
    "white":  "#ffffff"
  },

  "space": { "1":"4px","2":"8px","3":"12px","4":"16px","5":"22px","6":"28px","8":"40px" },

  "radius": { "sm":"8px","md":"16px","lg":"22px","pill":"999px","round":"50%" },

  "typography": {
    "fontSans": "-apple-system, BlinkMacSystemFont, \"Segoe UI\", \"Apple SD Gothic Neo\", \"Malgun Gothic\", sans-serif",
    "size": { "xs":"12px","sm":"13px","md":"14px","lg":"16px" },
    "weight": { "bold":700, "black":800 },
    "tracking": { "wide":"0.5px", "title":"3px" }
  },

  "motion": {
    "duration": { "fast":"0.06s","base":"0.15s","slow":"0.25s" },
    "easing": { "out":"ease" }
  },

  "shadow": {
    "float": "0 18px 40px -12px rgba(60,70,90,0.35)",
    "drop":  "0 24px 36px rgba(0,0,0,0.55)",
    "btn":   "0 8px 18px -6px rgba(160,120,210,0.7)"
  },

  "semantic": {
    "cute": {
      "bg": "{color.pink.50}",
      "bgDot": "{color.pink.300}",
      "surface": "rgba(255,255,255,0.55)",
      "surfaceEdge": "rgba(255,255,255,0.75)",
      "text": "{color.pink.700}",
      "textMuted": "{color.pink.400}",
      "title": "{color.pink.400}",
      "accent": "{color.pink.200}",
      "accent2": "{color.pink.100}",
      "onAccent": "{color.white}",
      "keycapFace": ["{color.white}", "#fdf4f7", "#f6e7ec"],
      "keycapSide": "#e3c9d3"
    },
    "dark": {
      "bg": "{color.night.700}",
      "surface": "rgba(255,255,255,0.92)",
      "text": "{color.purple.100}",
      "textMuted": "rgba(202,191,212,0.65)",
      "title": "{color.purple.300}",
      "accent": "{color.purple.400}",
      "accent2": "{color.purple.500}",
      "onAccent": "{color.white}",
      "toastText": "{color.purple.700}",
      "wax": {
        "top": "{color.wax.cream-50}",
        "mid": "{color.wax.cream-200}",
        "bottom": "{color.wax.cream-300}",
        "edge": "{color.wax.cream-400}",
        "rim": "{color.wax.cream-100}",
        "rimShadow": "{color.wax.shadow}",
        "chip": "{color.wax.cream-100}",
        "crack": "{color.wax.crack}"
      }
    }
  },

  "wakppuThemes": {
    "_note": "왁뿌볼 '속 색' 게임플레이 팔레트 (코팅 시 랜덤). 캔버스 JS에서 사용.",
    "솜사탕":   { "slime": ["#ffb3d9","#c9a7f0","#9ed1ff"], "beads": ["#ffffff","#fff3a8","#ffd1e8"] },
    "피스타치오": { "slime": ["#cfe89a","#8fc46b","#5d9648"], "beads": ["#7a4a2a","#fff6d8","#b5e08a"] },
    "그레이프":  { "slime": ["#d7b3ff","#a974e6","#6f3fb0"], "beads": ["#ffffff","#e7c6ff","#ffd86b"] },
    "피치":     { "slime": ["#ffd9a8","#ff9e7d","#f06a6a"], "beads": ["#fff3d8","#ffffff","#ffc4a8"] },
    "민트초코":  { "slime": ["#bff0e0","#7fd9c2","#4ea892"], "beads": ["#5a3b2a","#3a261a","#ffffff"] }
  }
}
